# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# USDA FoodData Central API
USDA_API_KEY=your-usda-api-key-here

# Local Development (when running `supabase start`)
# These will be automatically provided by Supabase CLI
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SUPABASE_ANON_KEY=will-be-provided-by-supabase-start
LOCAL_SUPABASE_SERVICE_ROLE_KEY=will-be-provided-by-supabase-start

# Environment
NODE_ENV=development
